{
  "name": "natsu",
  "private": true,
  "type": "module",
  "scripts": {
    "reader:build": "node reader/esbuild.config.mjs",
    "reader:typecheck": "tsc -p reader/tsconfig.json",
    "reader:test": "vitest run --config reader/vitest.config.mjs",
    "reader:lint": "eslint reader/src/",
    "reader:lint:fix": "eslint reader/src/ --fix",
    "reader:check": "npm run reader:typecheck && npm run reader:lint && npm run reader:test",
    "reader:format": "prettier --write reader/",
    "reader:format:check": "prettier --check reader/"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.32.0",
    "vitest": "^4.1.8"
  }
}
